HUGGINGFACEHUB_API_TOKEN=your_token_here
LANGSMITH_API_KEY=your_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=your_project_here
TAVILY_API_KEY=your_key_here
GOOGLE_API_KEY=your_key_here

# Hugging Face model names (examples)
HF_LLM_MODEL=your_model_name
HF_EMBEDDING_MODEL=your_embedding_model_name
RERANKER_MODEL=your_reranker_model


GOOGLE_EMBEDDING_MODEL=your_google_embedding_model_here
GOOGLE_LLM_MODEL=your_google_llm_model

# LLM provider: 'google', 'huggingface', etc.
LLM_PROVIDER=google
EMBEDDING_PROVIDER=your_embedding_provider_here

API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
API_ENABLE_STARTUP_WARMUP=false

# Notes:
# - Copy this file to `.env` and replace placeholders with real keys.
# - Keep `.env` out of version control (add to .gitignore).